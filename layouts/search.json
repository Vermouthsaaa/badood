[
{{- $pages := where site.RegularPages "Type" "not in" (slice "page") -}}
{{- range $index, $page := $pages -}}
  {{- if gt $index 0 }},{{ end }}
  {
    "title": {{ $page.Title | jsonify }},
    "permalink": {{ $page.Permalink | jsonify }},
    "summary": {{ $page.Summary | plainify | jsonify }}
  }
{{- end -}}
]
